{
  "name": "talab",
  "version": "1.0.0",
  "description": "Zero-dependency HTTP client for JavaScript & Typescript with results-based error handling.",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "bun build src/index.ts --minify --target=node --outfile=dist/talab.js",
    "test": "bun test",
    "check": "tsc --noEmit",
    "lint": "biome check . && tsc --noEmit",
    "lint:fix": "biome check --unsafe --write .",
    "format": "biome format --write .",
    "docs:dev": "cd docs && bun run dev",
    "docs:build": "cd docs && bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
