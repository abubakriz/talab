{
  "name": "@abubakriz/talab",
  "version": "1.0.1",
  "author": "Abu Bakr Iznain",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abubakriz/talab"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "http",
    "fetch",
    "request",
    "typescript",
    "javascript",
    "http-client",
    "web",
    "browser",
    "node"
  ],
  "description": "Zero-dependency HTTP client for JavaScript & Typescript with results-based error handling.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf ./dist && bun build src/index.ts --minify --sourcemap --target=node --outdir=./dist && tsc",
    "build:types": "tsc --emitDeclarationOnly",
    "test": "bun test",
    "check": "tsc --noEmit",
    "lint": "biome check . && tsc --noEmit",
    "lint:fix": "biome check --unsafe --write .",
    "format": "biome format --write .",
    "docs:dev": "cd docs && bun run dev",
    "docs:build": "cd docs && bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
